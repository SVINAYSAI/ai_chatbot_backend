# Database
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/restaurant_db
MONGODB_DB_NAME=restaurant_db

# Restaurant (create a restaurant first, then copy its ObjectId here)
RESTAURANT_ID=your-restaurant-object-id

# AI Providers — set only the keys you have. Router picks first available.
# Priority order: GEMINI → OPENAI → GROK → CLAUDE
GEMINI_API_KEY=
OPENAI_API_KEY=
GROK_API_KEY=
CLAUDE_API_KEY=

# JWT
JWT_SECRET=your-very-long-random-secret-key-min-32-characters
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# SMTP (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=your@gmail.com
SMTP_FROM_NAME=The Golden Fork

# App
APP_ENV=development
FRONTEND_URL=http://localhost:5173
